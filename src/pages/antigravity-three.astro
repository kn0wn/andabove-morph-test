---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Google Antigravity - Next-Generation IDE">
  <section class="hero">
    <canvas id="particleCanvas" class="hero-canvas"></canvas>
  </section>

  <script>
    // @ts-nocheck
    import * as THREE from "three";
    import { Pane } from "tweakpane";

    const STORAGE_KEY = "andabove:antigravity:params:v1";
    let particleSystem = null;
    let pane = null;
    const params = getDefaultParams();

    function getDefaultParams() {
      return {
        scene: {
          particleCount: 2000,
          gridSize: 50,
          cellSize: 3,
          zDepth: 5,
          cameraZ: 40,
        },
        motion: {
          timeStep: 0.012,
          mouseSmoothing: 0.1,
          magnetRadius: 40,
          minRadius: 3,
          maxRadius: 40,
          amplitude: 5,
          attractionForce: 0.3,
          breatheRadius: 40,
          breatheSpeed: 3,
          pulseSpeed: 4,
          stretchForce: 1.5,
        },
        blobs: {
          baseSize: 10,
          maxSize: 32,
          effectRadius: 40,
          halfWidth: 0.096,
          halfLength: 0.28,
          edgeSoftness: 0.08,
          opacityBase: 0.45,
          opacityCenter: 0.35,
          opacityMidBase: 0.5,
          opacityMidRange: 0.45,
          opacityOuterPeak: 0.95,
          opacityOuterFalloff: 0.35,
          opacityMin: 0.45,
          opacityMax: 1,
          finalAlphaScale: 1.12,
          finalAlphaOffset: 0.06,
        },
        colors: {
          centerPurple: "#E6BFFF",
          midOrange: "#FF7A5C",
          edgeOrange: "#FC4F00",
          localEdgeStart: 0.55,
          localEdgeStrength: 0.35,
          sceneBlendStart: 6,
          sceneBlendEnd: 42,
          colorMixStrength: 0.08,
        },
        grain: {
          intensity: 0.07,
          distScale: 0.5,
          displacementScale: 3,
        },
        brand: {
          text: "&above",
          color: "#FFFFFF",
          sizeMinRem: 3,
          sizeVw: 10,
          sizeMaxRem: 7,
          weight: 600,
          letterSpacingEm: -0.02,
        },
        textHover: {
          enabled: true,
          triggerPadding: 120,
          snapStrength: 0.32,
          snapDamping: 1,
          enterSmoothing: 0.2,
          exitSmoothing: 0.08,
          outlineSampling: 2,
          ambientSuppression: 1,
        },
      };
    }

    function deepClone(value) {
      return JSON.parse(JSON.stringify(value));
    }

    function clamp(value, min, max) {
      return Math.min(max, Math.max(min, value));
    }

    function sanitizeHexColor(value, fallback) {
      if (typeof value !== "string") return fallback;
      const normalized = value.startsWith("#") ? value : `#${value}`;
      return /^#[0-9a-fA-F]{6}$/.test(normalized) ? normalized : fallback;
    }

    function hexToVec3(hex) {
      const normalized = sanitizeHexColor(hex, "#FFFFFF");
      return new THREE.Color(normalized).toArray();
    }

    function assignKnown(target, source, template) {
      Object.keys(template).forEach(function eachKey(key) {
        const templateValue = template[key];
        const sourceValue = source && source[key];
        if (templateValue && typeof templateValue === "object" && !Array.isArray(templateValue)) {
          assignKnown(target[key], sourceValue || {}, templateValue);
          return;
        }
        if (typeof templateValue === "number") {
          if (typeof sourceValue === "number" && Number.isFinite(sourceValue)) {
            target[key] = sourceValue;
          }
          return;
        }
        if (typeof templateValue === "string") {
          if (typeof sourceValue === "string") {
            target[key] = sourceValue;
          }
          return;
        }
        if (typeof templateValue === "boolean") {
          if (typeof sourceValue === "boolean") {
            target[key] = sourceValue;
          }
        }
      });
    }

    function resetParams() {
      const defaults = getDefaultParams();
      assignKnown(params, defaults, defaults);
      sanitizeAllColorParams();
    }

    function sanitizeAllColorParams() {
      params.colors.centerPurple = sanitizeHexColor(params.colors.centerPurple, "#E6BFFF");
      params.colors.midOrange = sanitizeHexColor(params.colors.midOrange, "#FF7A5C");
      params.colors.edgeOrange = sanitizeHexColor(params.colors.edgeOrange, "#FC4F00");
      params.brand.color = sanitizeHexColor(params.brand.color, "#FFFFFF");
    }

    function getBrandLabel() {
      return params.brand.text || "&above";
    }

    class ParticleSystem {
      constructor(canvas, initialParams) {
        this.canvas = canvas;
        this.params = deepClone(initialParams);
        this.scene = null;
        this.camera = null;
        this.renderer = null;
        this.particles = null;
        this.material = null;
        this.geometry = null;
        this.positionArray = null;
        this.basePositions = null;
        this.outlineTargets = null;
        this.outlineAssignments = null;
        this.outlineCacheKey = "";
        this.textScreenRect = null;
        this.hoverStrength = 0;
        this.time = 0;
        this.animationId = null;
        this.mousePos = {
          x: window.innerWidth * 0.5,
          y: window.innerHeight * 0.5,
        };
        this.targetMousePos = {
          x: window.innerWidth * 0.5,
          y: window.innerHeight * 0.5,
        };
        this.raycaster = new THREE.Raycaster();
        this.mouse = new THREE.Vector2();
        this.planeZ = new THREE.Plane(new THREE.Vector3(0, 0, 1), 0);
        this.intersectPoint = new THREE.Vector3();

        this.onMouseMove = this.onMouseMove.bind(this);
        this.onWindowResize = this.onWindowResize.bind(this);
        this.onMouseLeave = this.onMouseLeave.bind(this);
        this.animate = this.animate.bind(this);

        this.init();
      }

      init() {
        this.scene = new THREE.Scene();
        this.camera = new THREE.PerspectiveCamera(
          75,
          window.innerWidth / window.innerHeight,
          0.1,
          1000,
        );
        this.camera.position.z = this.params.scene.cameraZ;

        this.renderer = new THREE.WebGLRenderer({
          canvas: this.canvas,
          antialias: true,
          alpha: true,
          powerPreference: "high-performance",
          precision: "highp",
        });
        this.renderer.setSize(window.innerWidth, window.innerHeight);
        this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        this.renderer.setClearColor(0x000000, 0);

        this.rebuildSystem();
        window.addEventListener("mousemove", this.onMouseMove);
        window.addEventListener("mouseleave", this.onMouseLeave);
        window.addEventListener("resize", this.onWindowResize);
        this.animate();
      }

      buildGeometry() {
        const sceneParams = this.params.scene;
        const geometry = new THREE.BufferGeometry();
        const particleCount = sceneParams.particleCount;
        const positions = new Float32Array(particleCount * 3);
        const velocities = new Float32Array(particleCount * 3);
        const diagonalOffsets = new Float32Array(particleCount);

        for (let i = 0; i < particleCount; i += 1) {
          const row = Math.floor(i / sceneParams.gridSize);
          const col = i % sceneParams.gridSize;

          let baseX = (col - sceneParams.gridSize / 2) * sceneParams.cellSize;
          if (row % 2 !== 0) {
            baseX += sceneParams.cellSize * 0.5;
          }

          const baseY = (row - sceneParams.gridSize / 2) * sceneParams.cellSize;
          positions[i * 3] = baseX;
          positions[i * 3 + 1] = baseY;
          positions[i * 3 + 2] = (Math.random() - 0.5) * sceneParams.zDepth;
          velocities[i * 3] = 0;
          velocities[i * 3 + 1] = 0;
          velocities[i * 3 + 2] = 0;
          diagonalOffsets[i] = 0;
        }

        geometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
        geometry.setAttribute("velocity", new THREE.BufferAttribute(velocities, 3));
        geometry.setAttribute("diagonalOffset", new THREE.BufferAttribute(diagonalOffsets, 1));
        return geometry;
      }

      buildShaders() {
        const vertexShader = `
          attribute vec3 velocity;
          attribute float diagonalOffset;
          uniform vec3 mousePos;
          uniform float time;
          uniform float hoverStrength;
          uniform float magnetRadius;
          uniform float minRadius;
          uniform float maxRadius;
          uniform float amplitude;
          uniform float attractionForce;
          uniform float breatheRadius;
          uniform float breatheSpeed;
          uniform float pulseSpeed;
          uniform float stretchForce;
          uniform float baseSize;
          uniform float maxSize;
          uniform float effectRadius;
          uniform float opacityBase;
          uniform float opacityCenter;
          uniform float opacityMidBase;
          uniform float opacityMidRange;
          uniform float opacityOuterPeak;
          uniform float opacityOuterFalloff;
          uniform float opacityMin;
          uniform float opacityMax;

          varying float vOpacity;
          varying float vWaveDisplacement;
          varying float vRotationAngle;
          varying float vDistToMouse;
          varying float vTiltAngle;

          void main() {
            vec3 pos = position;
            // Disable mouse influence as soon as text-hover formation engages.
            float mouseGate = 1.0 - smoothstep(0.02, 0.12, hoverStrength);
            float interactionDist = length(pos.xy - mousePos.xy);
            vec2 visualFocus = mix(vec2(0.0, 0.0), mousePos.xy, mouseGate);
            float distToMouse = length(pos.xy - visualFocus);
            vDistToMouse = distToMouse;

            float wave = 0.0;
            if (mouseGate > 0.0 && interactionDist < magnetRadius) {
              if (interactionDist > minRadius && interactionDist < maxRadius) {
                float normalizedDist = (interactionDist - minRadius) / (maxRadius - minRadius);
                float decay = sin(normalizedDist * 3.14159);
                wave = amplitude * decay;
                vec2 direction = normalize(mousePos.xy - pos.xy);
                pos.xy += direction * (amplitude * decay * attractionForce * mouseGate);
              }
              vRotationAngle = (atan(mousePos.y - pos.y, mousePos.x - pos.x) + 1.5708) * mouseGate;
              float horizontalDist = length(mousePos.xy - pos.xy);
              vTiltAngle = atan(mousePos.z - pos.z, horizontalDist) * mouseGate;
            } else {
              vRotationAngle = 0.0;
              vTiltAngle = 0.0;
            }

            pos.z += wave;
            vWaveDisplacement = wave;

            if (mouseGate > 0.0 && interactionDist < breatheRadius) {
              float t = interactionDist / breatheRadius;
              float breatheGate = mouseGate;
              float breath = sin(time * breatheSpeed - interactionDist * 0.2) * breatheGate;
              vec2 toMouse = mousePos.xy - pos.xy;
              vec2 dir = normalize(toMouse);
              pos.xy -= dir * (breath * (1.0 - t) * stretchForce);
            }

            float opacity = opacityBase;
            if (distToMouse < 10.0) {
              opacity = opacityCenter;
            } else if (distToMouse < 15.0) {
              float zoneFactor = (distToMouse - 3.0) / 12.0;
              opacity = opacityMidBase + zoneFactor * opacityMidRange;
            } else if (distToMouse < 30.0) {
              float zoneFactor = (distToMouse - 15.0) / 25.0;
              opacity = opacityOuterPeak - zoneFactor * opacityOuterFalloff;
            }
            vOpacity = clamp(opacity, opacityMin, opacityMax);

            gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);

            float particleSize = baseSize;
            if (mouseGate > 0.0 && interactionDist < effectRadius) {
              float t = interactionDist / effectRadius;
              t = t * t * (3.0 - 2.0 * t);
              float zoomFactor = 1.0 - t;
              float wavePhase = interactionDist * 0.5;
              float pulse = sin(time * pulseSpeed - wavePhase) * mouseGate;
              float heightFactor = 1.0 + pulse * 0.3;
              particleSize = (baseSize + (maxSize - baseSize) * zoomFactor) * heightFactor;
            }

            // Freeze dot size during hover text lock.
            float hoverLock = smoothstep(0.02, 0.12, hoverStrength);
            particleSize = mix(particleSize, baseSize, hoverLock);

            gl_PointSize = particleSize;
          }
        `;

        const fragmentShader = `
          uniform vec3 centerPurple;
          uniform vec3 midOrange;
          uniform vec3 edgeOrange;
          uniform float localEdgeStart;
          uniform float localEdgeStrength;
          uniform float sceneBlendStart;
          uniform float sceneBlendEnd;
          uniform float colorMixStrength;
          uniform float grainIntensity;
          uniform float grainDistScale;
          uniform float grainDisplacementScale;
          uniform float edgeSoftness;
          uniform float finalAlphaScale;
          uniform float finalAlphaOffset;

          varying float vOpacity;
          varying float vWaveDisplacement;
          varying float vRotationAngle;
          varying float vDistToMouse;
          varying float vTiltAngle;

          float grainNoise(vec2 p) {
            return fract(sin(dot(p, vec2(12.9898, 78.233))) * 43758.5453);
          }

          void main() {
            vec2 uv = gl_PointCoord - vec2(0.5);
            float c = cos(vRotationAngle);
            float s = sin(vRotationAngle);
            vec2 rotatedUV = vec2(uv.x * c - uv.y * s, uv.x * s + uv.y * c);

            float tiltCos = cos(vTiltAngle);
            float compressedX = rotatedUV.x * abs(tiltCos);
            float dX = abs(compressedX) / ${this.params.blobs.halfWidth.toFixed(6)};
            float dY = abs(rotatedUV.y) / ${this.params.blobs.halfLength.toFixed(6)};
            if (dX * dX + dY * dY > 1.0) {
              discard;
            }

            float distFromCenter = sqrt(dX * dX + dY * dY);
            float edgeFalloff = 1.0 - distFromCenter;
            edgeFalloff = smoothstep(0.0, edgeSoftness, edgeFalloff);
            float alpha = clamp(edgeFalloff * vOpacity, 0.0, 1.0);

            float displacement = abs(vWaveDisplacement);
            float colorMixFactor = clamp(displacement / 15.0, 0.0, 1.0);
            float radialDistance = clamp(distFromCenter, 0.0, 1.0);
            float localEdgeBlend = smoothstep(localEdgeStart, 1.0, radialDistance);
            float sceneBlend = smoothstep(sceneBlendStart, sceneBlendEnd, vDistToMouse);

            vec3 sceneColor = mix(centerPurple, midOrange, sceneBlend);
            vec3 finalColor = mix(sceneColor, edgeOrange, localEdgeBlend * localEdgeStrength);
            finalColor = mix(finalColor, edgeOrange, colorMixFactor * colorMixStrength);

            float grain = grainNoise(
              gl_FragCoord.xy + vec2(vDistToMouse * grainDistScale, displacement * grainDisplacementScale)
            );
            float grainAmount = (grain - 0.5) * grainIntensity;
            finalColor *= 1.0 + grainAmount;
            finalColor = clamp(finalColor, 0.0, 1.0);

            float finalAlpha = clamp(alpha * finalAlphaScale + finalAlphaOffset, 0.0, 1.0);
            gl_FragColor = vec4(finalColor, finalAlpha);
          }
        `;

        return { vertexShader, fragmentShader };
      }

      createMaterial() {
        const shaders = this.buildShaders();
        this.material = new THREE.ShaderMaterial({
          vertexShader: shaders.vertexShader,
          fragmentShader: shaders.fragmentShader,
          uniforms: {
            mousePos: { value: new THREE.Vector3(0, 0, 0) },
            time: { value: 0 },
            hoverStrength: { value: 0 },
            magnetRadius: { value: this.params.motion.magnetRadius },
            minRadius: { value: this.params.motion.minRadius },
            maxRadius: { value: this.params.motion.maxRadius },
            amplitude: { value: this.params.motion.amplitude },
            attractionForce: { value: this.params.motion.attractionForce },
            breatheRadius: { value: this.params.motion.breatheRadius },
            breatheSpeed: { value: this.params.motion.breatheSpeed },
            pulseSpeed: { value: this.params.motion.pulseSpeed },
            stretchForce: { value: this.params.motion.stretchForce },
            baseSize: { value: this.params.blobs.baseSize },
            maxSize: { value: this.params.blobs.maxSize },
            effectRadius: { value: this.params.blobs.effectRadius },
            opacityBase: { value: this.params.blobs.opacityBase },
            opacityCenter: { value: this.params.blobs.opacityCenter },
            opacityMidBase: { value: this.params.blobs.opacityMidBase },
            opacityMidRange: { value: this.params.blobs.opacityMidRange },
            opacityOuterPeak: { value: this.params.blobs.opacityOuterPeak },
            opacityOuterFalloff: { value: this.params.blobs.opacityOuterFalloff },
            opacityMin: { value: this.params.blobs.opacityMin },
            opacityMax: { value: this.params.blobs.opacityMax },
            centerPurple: { value: new THREE.Vector3(...hexToVec3(this.params.colors.centerPurple)) },
            midOrange: { value: new THREE.Vector3(...hexToVec3(this.params.colors.midOrange)) },
            edgeOrange: { value: new THREE.Vector3(...hexToVec3(this.params.colors.edgeOrange)) },
            localEdgeStart: { value: this.params.colors.localEdgeStart },
            localEdgeStrength: { value: this.params.colors.localEdgeStrength },
            sceneBlendStart: { value: this.params.colors.sceneBlendStart },
            sceneBlendEnd: { value: this.params.colors.sceneBlendEnd },
            colorMixStrength: { value: this.params.colors.colorMixStrength },
            grainIntensity: { value: this.params.grain.intensity },
            grainDistScale: { value: this.params.grain.distScale },
            grainDisplacementScale: { value: this.params.grain.displacementScale },
            edgeSoftness: { value: this.params.blobs.edgeSoftness },
            finalAlphaScale: { value: this.params.blobs.finalAlphaScale },
            finalAlphaOffset: { value: this.params.blobs.finalAlphaOffset },
          },
          transparent: true,
          blending: THREE.NormalBlending,
        });
      }

      getBrandFontPx() {
        const minPx = this.params.brand.sizeMinRem * 16;
        const maxPx = this.params.brand.sizeMaxRem * 16;
        const vwPx = (window.innerWidth * this.params.brand.sizeVw) / 100;
        return clamp(vwPx, minPx, maxPx);
      }

      screenToWorld(screenX, screenY) {
        const fovRad = (this.camera.fov * Math.PI) / 180;
        const visibleHeight = 2 * Math.tan(fovRad / 2) * this.camera.position.z;
        const visibleWidth = visibleHeight * this.camera.aspect;
        const worldX = (screenX / window.innerWidth - 0.5) * visibleWidth;
        const worldY = (0.5 - screenY / window.innerHeight) * visibleHeight;
        return { x: worldX, y: worldY };
      }

      buildOutlineAssignments(targets) {
        const particleCount = this.params.scene.particleCount;
        if (!targets || targets.length === 0 || !this.basePositions) {
          this.outlineAssignments = null;
          return;
        }

        const particleOrder = new Array(particleCount);
        for (let i = 0; i < particleCount; i += 1) {
          const posIndex = i * 3;
          const px = this.basePositions[posIndex];
          const py = this.basePositions[posIndex + 1];
          particleOrder[i] = {
            index: i,
            angle: Math.atan2(py, px),
            radius: px * px + py * py,
          };
        }
        particleOrder.sort(function byAngle(a, b) {
          if (a.angle === b.angle) return a.radius - b.radius;
          return a.angle - b.angle;
        });

        const targetOrder = new Array(targets.length);
        for (let i = 0; i < targets.length; i += 1) {
          const tx = targets[i].x;
          const ty = targets[i].y;
          targetOrder[i] = {
            index: i,
            angle: Math.atan2(ty, tx),
            radius: tx * tx + ty * ty,
          };
        }
        targetOrder.sort(function byAngle(a, b) {
          if (a.angle === b.angle) return a.radius - b.radius;
          return a.angle - b.angle;
        });

        const assignments = new Int32Array(particleCount);
        for (let rank = 0; rank < particleCount; rank += 1) {
          const particle = particleOrder[rank];
          const t = Math.floor((rank / particleCount) * targetOrder.length);
          const target = targetOrder[Math.min(targetOrder.length - 1, t)];
          assignments[particle.index] = target.index;
        }
        this.outlineAssignments = assignments;
      }

      buildOutlinePointCloud() {
        const text = getBrandLabel();
        if (!text) {
          this.textScreenRect = null;
          this.outlineAssignments = null;
          return [];
        }

        const fontPx = this.getBrandFontPx();
        const weight = Math.round(this.params.brand.weight);
        const sampling = Math.max(1, Math.round(this.params.textHover.outlineSampling));
        const outlineKey = `${text}|${fontPx}|${weight}|${sampling}|${window.innerWidth}|${window.innerHeight}|${this.params.scene.particleCount}`;
        if (outlineKey === this.outlineCacheKey && this.outlineTargets) {
          return this.outlineTargets;
        }

        const offscreen = document.createElement("canvas");
        const ctx = offscreen.getContext("2d");
        const padding = Math.ceil(fontPx * 0.45);
        const letterSpacingPx = fontPx * this.params.brand.letterSpacingEm;
        ctx.font = `${weight} ${fontPx}px "Google Sans Flex", Arial, sans-serif`;
        ctx.textBaseline = "alphabetic";
        ctx.textAlign = "left";

        const metrics = ctx.measureText(text);
        const spacingExtra = Math.max(0, text.length - 1) * letterSpacingPx;
        const measuredWidth = metrics.width + spacingExtra;
        const width = Math.max(16, Math.ceil(measuredWidth + padding * 2));
        const height = Math.max(
          16,
          Math.ceil(
            (metrics.actualBoundingBoxAscent || fontPx * 0.78) +
              (metrics.actualBoundingBoxDescent || fontPx * 0.22) +
              padding * 2,
          ),
        );
        offscreen.width = width;
        offscreen.height = height;
        ctx.clearRect(0, 0, width, height);
        ctx.font = `${weight} ${fontPx}px "Google Sans Flex", Arial, sans-serif`;
        ctx.fillStyle = "#ffffff";
        const drawX = padding;
        const drawY = padding + (metrics.actualBoundingBoxAscent || fontPx * 0.78);
        if (Math.abs(letterSpacingPx) < 0.001) {
          ctx.fillText(text, drawX, drawY);
        } else {
          let cursorX = drawX;
          for (let i = 0; i < text.length; i += 1) {
            const char = text[i];
            ctx.fillText(char, cursorX, drawY);
            cursorX += ctx.measureText(char).width + letterSpacingPx;
          }
        }

        const imageData = ctx.getImageData(0, 0, width, height);
        const pixels = imageData.data;
        const alphaAt = function alphaAt(x, y) {
          if (x < 0 || y < 0 || x >= width || y >= height) return 0;
          return pixels[(y * width + x) * 4 + 3];
        };

        const edgePixels = [];
        for (let y = 1; y < height - 1; y += sampling) {
          for (let x = 1; x < width - 1; x += sampling) {
            const alpha = alphaAt(x, y);
            if (alpha < 40) continue;
            const neighborClear =
              alphaAt(x - 1, y) < 40 ||
              alphaAt(x + 1, y) < 40 ||
              alphaAt(x, y - 1) < 40 ||
              alphaAt(x, y + 1) < 40;
            if (neighborClear) {
              edgePixels.push({ x, y });
            }
          }
        }

        if (edgePixels.length === 0) {
          this.textScreenRect = null;
          this.outlineAssignments = null;
          return [];
        }

        const pxToScreenX = window.innerWidth * 0.5 - width * 0.5;
        const pxToScreenY = window.innerHeight * 0.5 - height * 0.5;
        this.textScreenRect = {
          left: pxToScreenX,
          top: pxToScreenY,
          right: pxToScreenX + width,
          bottom: pxToScreenY + height,
          width,
          height,
        };
        const targetCount = this.params.scene.particleCount;
        const points = new Array(targetCount);
        const step = edgePixels.length / targetCount;

        for (let i = 0; i < targetCount; i += 1) {
          const sourceIdx = Math.min(Math.floor(i * step), edgePixels.length - 1);
          const source = edgePixels[sourceIdx];
          const screenX = pxToScreenX + source.x;
          const screenY = pxToScreenY + source.y;
          const world = this.screenToWorld(screenX, screenY);
          points[i] = {
            x: world.x,
            y: world.y,
          };
        }

        this.outlineCacheKey = outlineKey;
        this.outlineTargets = points;
        this.buildOutlineAssignments(points);
        return points;
      }

      getHoverTargetStrength() {
        if (!this.params.textHover.enabled || !this.textScreenRect) return 0;
        const rect = this.textScreenRect;
        const px = this.mousePos.x;
        const py = this.mousePos.y;
        const padding = Math.max(0, this.params.textHover.triggerPadding);

        const dx = Math.max(rect.left - px, 0, px - rect.right);
        const dy = Math.max(rect.top - py, 0, py - rect.bottom);
        const outsideDistance = Math.sqrt(dx * dx + dy * dy);

        if (outsideDistance > padding) return 0;
        if (padding === 0) return dx === 0 && dy === 0 ? 1 : 0;
        return 1 - outsideDistance / padding;
      }

      applyOutlineInfluence() {
        if (!this.positionArray || !this.basePositions || !this.geometry) return;
        const targets = this.buildOutlinePointCloud();
        const targetStrength = this.getHoverTargetStrength();
        const smooth =
          targetStrength > this.hoverStrength
            ? this.params.textHover.enterSmoothing
            : this.params.textHover.exitSmoothing;
        this.hoverStrength += (targetStrength - this.hoverStrength) * clamp(smooth, 0.001, 1);

        const lerpBase = clamp(this.params.textHover.snapStrength, 0.001, 1);
        const damping = clamp(this.params.textHover.snapDamping, 0, 1);
        const blend = this.hoverStrength;
        const pointCount = targets.length;
        const activeCount = Math.min(pointCount, this.params.scene.particleCount);

        for (let i = 0; i < this.params.scene.particleCount; i += 1) {
          const posIndex = i * 3;
          const baseX = this.basePositions[posIndex];
          const baseY = this.basePositions[posIndex + 1];
          const baseZ = this.basePositions[posIndex + 2];

          let targetX = baseX;
          let targetY = baseY;
          if (activeCount > 0) {
            const mappedIndex =
              this.outlineAssignments && Number.isInteger(this.outlineAssignments[i])
                ? this.outlineAssignments[i]
                : i % activeCount;
            const point = targets[Math.max(0, Math.min(activeCount - 1, mappedIndex))];
            targetX = baseX * (1 - blend) + point.x * blend;
            targetY = baseY * (1 - blend) + point.y * blend;
          }

          const lerpFactor = clamp(
            lerpBase * (0.35 + blend * (0.65 + damping)),
            0.001,
            1,
          );
          this.positionArray[posIndex] += (targetX - this.positionArray[posIndex]) * lerpFactor;
          this.positionArray[posIndex + 1] +=
            (targetY - this.positionArray[posIndex + 1]) * lerpFactor;
          this.positionArray[posIndex + 2] +=
            (baseZ - this.positionArray[posIndex + 2]) * clamp(lerpFactor * 0.5, 0.001, 1);
        }

        this.geometry.attributes.position.needsUpdate = true;
      }

      updateUniforms() {
        if (!this.material) return;
        const uniforms = this.material.uniforms;
        uniforms.magnetRadius.value = this.params.motion.magnetRadius;
        uniforms.minRadius.value = this.params.motion.minRadius;
        uniforms.maxRadius.value = this.params.motion.maxRadius;
        uniforms.amplitude.value = this.params.motion.amplitude;
        uniforms.attractionForce.value = this.params.motion.attractionForce;
        uniforms.breatheRadius.value = this.params.motion.breatheRadius;
        uniforms.breatheSpeed.value = this.params.motion.breatheSpeed;
        uniforms.pulseSpeed.value = this.params.motion.pulseSpeed;
        uniforms.stretchForce.value = this.params.motion.stretchForce;
        uniforms.baseSize.value = this.params.blobs.baseSize;
        uniforms.maxSize.value = this.params.blobs.maxSize;
        uniforms.effectRadius.value = this.params.blobs.effectRadius;
        uniforms.opacityBase.value = this.params.blobs.opacityBase;
        uniforms.opacityCenter.value = this.params.blobs.opacityCenter;
        uniforms.opacityMidBase.value = this.params.blobs.opacityMidBase;
        uniforms.opacityMidRange.value = this.params.blobs.opacityMidRange;
        uniforms.opacityOuterPeak.value = this.params.blobs.opacityOuterPeak;
        uniforms.opacityOuterFalloff.value = this.params.blobs.opacityOuterFalloff;
        uniforms.opacityMin.value = this.params.blobs.opacityMin;
        uniforms.opacityMax.value = this.params.blobs.opacityMax;
        uniforms.centerPurple.value.set(...hexToVec3(this.params.colors.centerPurple));
        uniforms.midOrange.value.set(...hexToVec3(this.params.colors.midOrange));
        uniforms.edgeOrange.value.set(...hexToVec3(this.params.colors.edgeOrange));
        uniforms.localEdgeStart.value = this.params.colors.localEdgeStart;
        uniforms.localEdgeStrength.value = this.params.colors.localEdgeStrength;
        uniforms.sceneBlendStart.value = this.params.colors.sceneBlendStart;
        uniforms.sceneBlendEnd.value = this.params.colors.sceneBlendEnd;
        uniforms.colorMixStrength.value = this.params.colors.colorMixStrength;
        uniforms.grainIntensity.value = this.params.grain.intensity;
        uniforms.grainDistScale.value = this.params.grain.distScale;
        uniforms.grainDisplacementScale.value = this.params.grain.displacementScale;
        uniforms.edgeSoftness.value = this.params.blobs.edgeSoftness;
        uniforms.finalAlphaScale.value = this.params.blobs.finalAlphaScale;
        uniforms.finalAlphaOffset.value = this.params.blobs.finalAlphaOffset;
        uniforms.hoverStrength.value = this.hoverStrength;
      }

      rebuildSystem() {
        if (this.particles) {
          this.scene.remove(this.particles);
          if (this.particles.geometry) this.particles.geometry.dispose();
        }
        if (this.material) this.material.dispose();

        this.camera.position.z = this.params.scene.cameraZ;
        const geometry = this.buildGeometry();
        this.createMaterial();
        this.geometry = geometry;
        this.positionArray = geometry.attributes.position.array;
        this.basePositions = new Float32Array(this.positionArray);
        this.outlineCacheKey = "";
        this.outlineTargets = null;
        this.outlineAssignments = null;
        this.particles = new THREE.Points(this.geometry, this.material);
        this.scene.add(this.particles);
        this.buildOutlinePointCloud();
      }

      setParams(nextParams, requiresRebuild) {
        this.params = deepClone(nextParams);
        sanitizeAllColorParams();
        this.outlineCacheKey = "";
        if (requiresRebuild) {
          this.rebuildSystem();
        } else {
          this.updateUniforms();
          this.buildOutlinePointCloud();
        }
      }

      onMouseMove(e) {
        this.targetMousePos.x = e.clientX;
        this.targetMousePos.y = e.clientY;
      }

      onMouseLeave() {
        this.targetMousePos.x = window.innerWidth * 0.5;
        this.targetMousePos.y = window.innerHeight * 0.5;
      }

      onWindowResize() {
        this.camera.aspect = window.innerWidth / window.innerHeight;
        this.camera.updateProjectionMatrix();
        this.renderer.setSize(window.innerWidth, window.innerHeight);
        this.outlineCacheKey = "";
        this.buildOutlinePointCloud();
      }

      animate() {
        this.animationId = requestAnimationFrame(this.animate);
        this.time += this.params.motion.timeStep;

        const smoothing = clamp(this.params.motion.mouseSmoothing, 0.01, 1.0);
        this.mousePos.x += (this.targetMousePos.x - this.mousePos.x) * smoothing;
        this.mousePos.y += (this.targetMousePos.y - this.mousePos.y) * smoothing;

        this.mouse.x = (this.mousePos.x / window.innerWidth) * 2 - 1;
        this.mouse.y = -(this.mousePos.y / window.innerHeight) * 2 + 1;
        this.raycaster.setFromCamera(this.mouse, this.camera);
        this.raycaster.ray.intersectPlane(this.planeZ, this.intersectPoint);
        this.material.uniforms.mousePos.value.set(
          this.intersectPoint.x,
          this.intersectPoint.y,
          0,
        );
        this.applyOutlineInfluence();
        const ambientSuppression = clamp(this.params.textHover.ambientSuppression, 0, 1);
        this.material.uniforms.amplitude.value =
          this.params.motion.amplitude * (1 - this.hoverStrength * ambientSuppression);
        this.material.uniforms.hoverStrength.value = this.hoverStrength;
        this.material.uniforms.time.value = this.time;

        this.renderer.render(this.scene, this.camera);
      }

      dispose() {
        if (this.animationId) cancelAnimationFrame(this.animationId);
        window.removeEventListener("mousemove", this.onMouseMove);
        window.removeEventListener("mouseleave", this.onMouseLeave);
        window.removeEventListener("resize", this.onWindowResize);
        if (this.particles && this.particles.geometry) this.particles.geometry.dispose();
        if (this.material) this.material.dispose();
        if (this.renderer) this.renderer.dispose();
      }
    }

    function applyParams(requiresRebuild) {
      sanitizeAllColorParams();
      if (particleSystem) {
        particleSystem.setParams(params, requiresRebuild);
      }
    }

    function saveLocalPreset() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(params));
    }

    function loadLocalPreset() {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return false;
      try {
        const parsed = JSON.parse(raw);
        assignKnown(params, parsed, getDefaultParams());
        sanitizeAllColorParams();
        return true;
      } catch (error) {
        console.warn("Failed to parse local preset", error);
        return false;
      }
    }

    function exportJsonPreset() {
      const json = JSON.stringify(params, null, 2);
      const blob = new Blob([json], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = "andabove-antigravity-preset.json";
      link.click();
      URL.revokeObjectURL(url);
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(json).catch(function noop() {});
      }
    }

    function importJsonPreset() {
      const incoming = window.prompt("Paste preset JSON");
      if (!incoming) return;
      try {
        const parsed = JSON.parse(incoming);
        assignKnown(params, parsed, getDefaultParams());
        sanitizeAllColorParams();
        if (pane) pane.refresh();
        applyParams(true);
      } catch (error) {
        window.alert("Invalid JSON preset");
      }
    }

    function registerBinding(folder, objectRef, key, options, requiresRebuild) {
      const binding = folder.addBinding(objectRef, key, options);
      binding.on("change", function onBindingChange() {
        applyParams(requiresRebuild);
      });
      return binding;
    }

    function buildPane() {
      pane = new Pane({ title: "Designer Controls", expanded: true });

      const sceneFolder = pane.addFolder({ title: "Scene" });
      registerBinding(sceneFolder, params.scene, "particleCount", { min: 200, max: 6000, step: 100 }, true);
      registerBinding(sceneFolder, params.scene, "gridSize", { min: 10, max: 120, step: 1 }, true);
      registerBinding(sceneFolder, params.scene, "cellSize", { min: 1, max: 8, step: 0.1 }, true);
      registerBinding(sceneFolder, params.scene, "zDepth", { min: 0, max: 30, step: 0.1 }, true);
      registerBinding(sceneFolder, params.scene, "cameraZ", { min: 10, max: 80, step: 1 }, true);

      const motionFolder = pane.addFolder({ title: "Motion" });
      registerBinding(motionFolder, params.motion, "timeStep", { min: 0.001, max: 0.08, step: 0.001 }, false);
      registerBinding(motionFolder, params.motion, "mouseSmoothing", { min: 0.01, max: 0.5, step: 0.01 }, false);
      registerBinding(motionFolder, params.motion, "magnetRadius", { min: 5, max: 120, step: 1 }, false);
      registerBinding(motionFolder, params.motion, "minRadius", { min: 0, max: 20, step: 0.1 }, false);
      registerBinding(motionFolder, params.motion, "maxRadius", { min: 10, max: 180, step: 1 }, false);
      registerBinding(motionFolder, params.motion, "amplitude", { min: 0, max: 20, step: 0.1 }, false);
      registerBinding(motionFolder, params.motion, "attractionForce", { min: 0, max: 2, step: 0.01 }, false);
      registerBinding(motionFolder, params.motion, "breatheRadius", { min: 0, max: 120, step: 1 }, false);
      registerBinding(motionFolder, params.motion, "breatheSpeed", { min: 0, max: 12, step: 0.1 }, false);
      registerBinding(motionFolder, params.motion, "pulseSpeed", { min: 0, max: 12, step: 0.1 }, false);
      registerBinding(motionFolder, params.motion, "stretchForce", { min: 0, max: 6, step: 0.1 }, false);

      const blobsFolder = pane.addFolder({ title: "Blobs" });
      registerBinding(blobsFolder, params.blobs, "baseSize", { min: 1, max: 40, step: 0.1 }, false);
      registerBinding(blobsFolder, params.blobs, "maxSize", { min: 1, max: 80, step: 0.1 }, false);
      registerBinding(blobsFolder, params.blobs, "effectRadius", { min: 1, max: 120, step: 1 }, false);
      registerBinding(blobsFolder, params.blobs, "halfWidth", { min: 0.01, max: 0.6, step: 0.005 }, true);
      registerBinding(blobsFolder, params.blobs, "halfLength", { min: 0.01, max: 1.2, step: 0.005 }, true);
      registerBinding(blobsFolder, params.blobs, "edgeSoftness", { min: 0.01, max: 0.3, step: 0.005 }, false);
      registerBinding(blobsFolder, params.blobs, "opacityBase", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(blobsFolder, params.blobs, "opacityCenter", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(blobsFolder, params.blobs, "opacityMidBase", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(blobsFolder, params.blobs, "opacityMidRange", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(blobsFolder, params.blobs, "opacityOuterPeak", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(blobsFolder, params.blobs, "opacityOuterFalloff", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(blobsFolder, params.blobs, "opacityMin", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(blobsFolder, params.blobs, "opacityMax", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(blobsFolder, params.blobs, "finalAlphaScale", { min: 0, max: 2, step: 0.01 }, false);
      registerBinding(blobsFolder, params.blobs, "finalAlphaOffset", { min: -1, max: 1, step: 0.01 }, false);

      const colorsFolder = pane.addFolder({ title: "Colors" });
      registerBinding(colorsFolder, params.colors, "centerPurple", { view: "color" }, false);
      registerBinding(colorsFolder, params.colors, "midOrange", { view: "color" }, false);
      registerBinding(colorsFolder, params.colors, "edgeOrange", { view: "color" }, false);
      registerBinding(colorsFolder, params.colors, "localEdgeStart", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(colorsFolder, params.colors, "localEdgeStrength", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(colorsFolder, params.colors, "sceneBlendStart", { min: 0, max: 80, step: 1 }, false);
      registerBinding(colorsFolder, params.colors, "sceneBlendEnd", { min: 1, max: 120, step: 1 }, false);
      registerBinding(colorsFolder, params.colors, "colorMixStrength", { min: 0, max: 1, step: 0.01 }, false);

      const grainFolder = pane.addFolder({ title: "Grain" });
      registerBinding(grainFolder, params.grain, "intensity", { min: 0, max: 0.5, step: 0.005 }, false);
      registerBinding(grainFolder, params.grain, "distScale", { min: 0, max: 3, step: 0.01 }, false);
      registerBinding(grainFolder, params.grain, "displacementScale", { min: 0, max: 10, step: 0.1 }, false);

      const brandFolder = pane.addFolder({ title: "Brand" });
      registerBinding(brandFolder, params.brand, "text", {}, false);
      registerBinding(brandFolder, params.brand, "color", { view: "color" }, false);
      registerBinding(brandFolder, params.brand, "sizeMinRem", { min: 0.5, max: 10, step: 0.1 }, false);
      registerBinding(brandFolder, params.brand, "sizeVw", { min: 1, max: 20, step: 0.1 }, false);
      registerBinding(brandFolder, params.brand, "sizeMaxRem", { min: 1, max: 20, step: 0.1 }, false);
      registerBinding(brandFolder, params.brand, "weight", { min: 100, max: 900, step: 1 }, false);
      registerBinding(brandFolder, params.brand, "letterSpacingEm", { min: -0.2, max: 0.2, step: 0.005 }, false);

      const textHoverFolder = pane.addFolder({ title: "Text Hover" });
      registerBinding(textHoverFolder, params.textHover, "enabled", {}, false);
      registerBinding(textHoverFolder, params.textHover, "triggerPadding", { min: 0, max: 400, step: 1 }, false);
      registerBinding(textHoverFolder, params.textHover, "snapStrength", { min: 0.01, max: 1, step: 0.01 }, false);
      registerBinding(textHoverFolder, params.textHover, "snapDamping", { min: 0, max: 1, step: 0.01 }, false);
      registerBinding(textHoverFolder, params.textHover, "enterSmoothing", { min: 0.01, max: 1, step: 0.01 }, false);
      registerBinding(textHoverFolder, params.textHover, "exitSmoothing", { min: 0.01, max: 1, step: 0.01 }, false);
      registerBinding(textHoverFolder, params.textHover, "outlineSampling", { min: 1, max: 8, step: 1 }, false);
      registerBinding(textHoverFolder, params.textHover, "ambientSuppression", { min: 0, max: 1, step: 0.01 }, false);

      const presetsFolder = pane.addFolder({ title: "Presets" });
      presetsFolder.addButton({ title: "Save Local" }).on("click", function onSaveLocal() {
        saveLocalPreset();
      });
      presetsFolder.addButton({ title: "Load Local" }).on("click", function onLoadLocal() {
        if (loadLocalPreset()) {
          pane.refresh();
          applyParams(true);
        }
      });
      presetsFolder.addButton({ title: "Export JSON" }).on("click", function onExportJson() {
        exportJsonPreset();
      });
      presetsFolder.addButton({ title: "Import JSON" }).on("click", function onImportJson() {
        importJsonPreset();
      });
      presetsFolder.addButton({ title: "Reset Defaults" }).on("click", function onResetDefaults() {
        resetParams();
        pane.refresh();
        applyParams(true);
      });
    }

    window.addEventListener("load", function handleLoad() {
      loadLocalPreset();
      const canvas = document.getElementById("particleCanvas");
      particleSystem = new ParticleSystem(canvas, params);
      buildPane();
      applyParams(true);
    });

    window.addEventListener("beforeunload", function handleUnload() {
      if (pane) pane.dispose();
      if (particleSystem) particleSystem.dispose();
    });
  </script>

  <style is:global>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html,
    body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      font-family: "Google Sans Flex", Arial, sans-serif;
      background: #ffffff;
    }

    .hero {
      position: relative;
      width: 100%;
      height: 100vh;
      overflow: hidden;
    }

    .hero-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }

    .tp-dfwv {
      position: fixed !important;
      top: 16px !important;
      right: 16px !important;
      left: auto !important;
      z-index: 20 !important;
      max-height: calc(100vh - 32px);
      overflow: auto;
    }
  </style>
</Layout>
