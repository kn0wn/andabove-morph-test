---
import Layout from "../layouts/Layout.astro";
---

<Layout title="&above">
  <main class="hero">
    <div id="ringParticlesRoot" class="hero-canvas" aria-hidden="true"></div>

    <div class="hero-overlay">
      <section class="hero-content" aria-label="Homepage hero">
        <img
          src="/andabove-wordmark.svg"
          alt="&above"
          class="hero-logo"
          width="135"
          height="28"
          loading="eager"
          decoding="async"
        />
        <h1 class="hero-copy">
          We help enterprise clients discover, build and embed AI so they can solve real challenges faster.
        </h1>
        <div class="hero-actions">
          <a href="/morph" class="hero-button hero-button-secondary">Morph</a>
          <a href="/ring-particles" class="hero-button hero-button-primary">Ring</a>
        </div>
      </section>
    </div>
  </main>

  <script>
    import {
      attachRingDevTools,
      shouldShowParticleGui,
    } from "../lib/dev/particleDevTools";
    import { RingParticleScene } from "../lib/ring-particles";

    let ringScene: InstanceType<typeof RingParticleScene> | null = null;
    let rafId = 0;
    let ringGui: { dispose(): void } | null = null;

    function tick() {
      ringScene?.render();
      rafId = requestAnimationFrame(tick);
    }

    function init() {
      const root = document.getElementById("ringParticlesRoot");
      if (!root) return;

      ringScene = new RingParticleScene({
        container: root,
        theme: "light",
        color1: "#F75D3B",
        color2: "#E85A4F",
        color3: "#FF8A65",
        pixelRatio: Math.min(window.devicePixelRatio, 2),
        interactive: true,
        onLoaded: (scene) => {
          if (shouldShowParticleGui()) ringGui = attachRingDevTools(scene);
          rafId = requestAnimationFrame(tick);
        },
      });

      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) ringScene?.resume();
            else ringScene?.stop();
          }
        },
        { threshold: 0 },
      );
      io.observe(root);

      window.addEventListener(
        "beforeunload",
        () => {
          cancelAnimationFrame(rafId);
          ringGui?.dispose();
          ringGui = null;
          io.disconnect();
          ringScene?.kill();
          ringScene = null;
        },
        { once: true },
      );
    }

    if (document.readyState === "complete") init();
    else window.addEventListener("load", init, { once: true });
  </script>

  <style is:global>
    :root {
      --slate: #262626;
      --chalk: #ffffff;
    }

    * {
      box-sizing: border-box;
    }

    html,
    body {
      width: 100%;
      min-height: 100%;
      margin: 0;
      overflow: hidden;
      background: var(--chalk);
      color: var(--slate);
      font-family: "Aeonik Pro", "Google Sans Flex", Arial, sans-serif;
    }

    body {
      min-height: 100vh;
    }

    .hero {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      isolation: isolate;
      background: var(--chalk);
    }

    .hero-canvas {
      position: absolute;
      inset: 0;
      z-index: 0;
      width: 100%;
      height: 100%;
      display: block;
      pointer-events: none;
    }

    .hero-canvas canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }

    .hero-overlay {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 2rem;
      pointer-events: none;
    }

    .hero-content {
      width: min(100%, 46rem);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      text-align: center;
      pointer-events: auto;
    }

    .hero-logo {
      width: 8.4375rem;
      height: auto;
      display: block;
    }

    .hero-copy {
      max-width: 46rem;
      margin: 0;
      font-size: clamp(1.875rem, 2.2vw, 1.9375rem);
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: 0;
      text-wrap: balance;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
    }

    .hero-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3rem;
      padding: 0.625rem 1.5rem;
      border-radius: 4.4375rem;
      border: 2px solid var(--slate);
      font: inherit;
      font-size: 1.125rem;
      font-weight: 500;
      line-height: 1.5;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      transition:
        transform 0.2s ease,
        background-color 0.2s ease,
        color 0.2s ease,
        opacity 0.2s ease;
    }

    .hero-button:hover {
      transform: translateY(-1px);
    }

    .hero-button-secondary {
      background: rgba(255, 255, 255, 0.84);
      color: var(--slate);
      backdrop-filter: blur(8px);
    }

    .hero-button-primary {
      background: var(--slate);
      color: var(--chalk);
    }

    @media (max-width: 48rem) {
      html,
      body {
        overflow: auto;
      }

      .hero-overlay {
        padding: 1.5rem;
      }

      .hero-content {
        gap: 1.25rem;
        width: min(100%, 32rem);
      }

      .hero-copy {
        font-size: clamp(1.625rem, 7vw, 2rem);
      }

      .hero-actions {
        width: 100%;
        flex-direction: column;
        align-items: stretch;
      }

      .hero-button {
        width: 100%;
      }
    }
  </style>
</Layout>
